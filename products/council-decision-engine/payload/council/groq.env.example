# Copy this file to groq.env in the same folder, then paste your key.
# Get a free key at https://console.groq.com/keys — the free tier covers
# roughly 100 council runs per day, far more than you will ever need.
#
# Keep groq.env out of version control and out of AI chat windows.
# Recommended: chmod 600 groq.env

GROQ_API_KEY=insert-your-groq-key-here
