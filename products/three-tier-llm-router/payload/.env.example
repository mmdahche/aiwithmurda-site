# 3-Tier LLM Router — environment configuration
#
# Copy this file to $ROUTER_HOME/.env (default $HOME/.router/.env) and fill in
# the values for the providers you want to enable. Any key left blank makes
# that tier report `ok: false` on `ping` and disables it in the cascade.
#
# The router reads .env once at module load; changing values requires a
# process restart. process.env values already set at spawn time win over
# anything in this file (standard dotenv precedence).

# ---------- Provider API keys ----------
GROQ_API_KEY=your-groq-key-here
FIREWORKS_API_KEY=your-fireworks-key-here
CEREBRAS_API_KEY=your-cerebras-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# ---------- Provider base URLs (only override for self-hosted proxies) ----------
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# OLLAMA_BASE_URL=http://localhost:11434

# ---------- Model overrides (env > model-roles.json > hardcoded) ----------
# Uncomment to override the model IDs from model-roles.json.
# TIER1_MODEL=qwen2.5:7b
# TIER2_MODEL=llama-3.3-70b-versatile
# TIER2_FALLBACK_MODEL=llama-3.1-8b-instant
# FIREWORKS_PRIMARY_MODEL=accounts/fireworks/models/deepseek-v3
# FIREWORKS_FALLBACK_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
# CEREBRAS_PRIMARY_MODEL=llama-3.3-70b
# CEREBRAS_FALLBACK_MODEL=llama-3.1-8b
# TIER3_MODEL=claude-opus-4-7

# ---------- Tier 1 (local Ollama) ----------
# Ollama is intentionally OFF by default — set to `true` to enable the local tier.
# When disabled, chat/light purposes route directly to the cheap remote tier.
LOCAL_OLLAMA_ENABLED=false

# ---------- Quota (rolling window over the recent call log) ----------
QUOTA_WINDOW_SIZE=50
QUOTA_TARGET_CHAT=0.30
QUOTA_TARGET_CHEAP=0.40
QUOTA_TARGET_PRECISION=0.30
QUOTA_TOLERANCE=0.10

# ---------- Egress redaction firewall ----------
# ON by default. Set to 0/false/no to disable (NOT recommended in production).
ROUTER_REDACT_ENABLED=1
# Behavior when a scrub fails or a secret is detected after scrub:
#   escalate  — bubble the call up to the precision (Anthropic) tier
#   abort     — throw immediately, no cloud send at all
ROUTER_REDACT_FAIL_MODE=escalate

# ---------- Confidence gate (opt-in early-exit for the local tier) ----------
# Set to 1 to enable. When OFF (default), any successful Ollama response is
# accepted; when ON, a low-confidence / hedged / empty response escalates.
ROUTER_CONFIDENCE_GATE_ENABLED=0
# Numeric cutoff for the self-reported confidence marker (0.0 - 1.0).
# ROUTER_CONFIDENCE_THRESHOLD=0.6

# ---------- Paths ----------
# Override the router's home directory. Defaults to $HOME/.router.
# ROUTER_HOME=/absolute/path/to/router-home
# Override the per-agent model-frontmatter directory. Defaults to $ROUTER_HOME/agents.
# ROUTER_AGENTS_DIR=/absolute/path/to/agents
# Override the JSONL call log. Defaults to $ROUTER_HOME/memory/tier-usage.jsonl.
# ROUTER_USAGE_LOG=/absolute/path/to/tier-usage.jsonl
# Override the root used by the response verifier for file-path existence checks.
# Defaults to $ROUTER_HOME.
# ROUTER_VERIFY_ROOT=/absolute/path/to/project-root
